# Configuração - WhatsApp Gemini Automation
# Copie para .env e preencha com seus valores

## Google Gemini API
GEMINI_API_KEY=seu-gemini-api-key-aqui
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_TOKENS=1000
GEMINI_TEMPERATURE=0.7

## Google BigQuery
GCP_PROJECT=seu-projeto-gcp
GCP_DATASET=whatsapp_gemini
GCP_KEYFILE=/path/to/service-account-key.json

## Meta WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=seu-phone-id
WHATSAPP_BUSINESS_ACCOUNT_ID=seu-business-account-id
WHATSAPP_ACCESS_TOKEN=seu-access-token-meta
WHATSAPP_VERIFY_TOKEN=seu-token-verificacao-webhook

## n8n Configuration
N8N_BASE_URL=https://seu-n8n.com
N8N_API_KEY=sua-api-key-n8n
WEBHOOK_PATH=/webhook/whatsapp-gemini

## Logging
LOG_LEVEL=info
LOG_TO_BQ=true

## Rate Limiting
RATE_LIMIT_PER_MINUTE=1000
RATE_LIMIT_PER_HOUR=50000

## Comportamento IA
SYSTEM_PROMPT=Você é um assistente de atendimento ao cliente amigável e profissional. Responda em português de forma concisa e útil.
CONTEXT_MESSAGES=10
MAX_RESPONSE_LENGTH=1000

## Notifications (opcional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/...
NOTIFICATION_ON_ERROR=true
